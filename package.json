{
  "name": "@mephisto5558/eslint-config",
  "version": "5.3.0",
  "description": "ESLint configuration",
  "keywords": [
    "eslint"
  ],
  "homepage": "https://github.com/Mephisto5558/ESLint-Config#readme",
  "bugs": {
    "url": "https://github.com/Mephisto5558/ESLint-Config/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Mephisto5558/ESLint-Config.git"
  },
  "license": "MIT",
  "author": "Mephisto5558",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "!**/*.tsbuildinfo",
    "configs",
    "dist",
    "tsconfigs"
  ],
  "scripts": {
    "build": "npm run clean && tsc -p ./tsconfig.build.json",
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true });\"",
    "lint": "eslint . --cache --cache-location ./node_modules/.cache/eslint/ >eslint.log",
    "test": "echo \"Error: no test specified\"",
    "watch": "npm run build -- --watch"
  },
  "overrides": {
    "baseline-browser-mapping": "latest"
  },
  "dependencies": {
    "@eslint-community/eslint-plugin-eslint-comments": "^4.7.1",
    "@eslint/compat": "2.x",
    "@eslint/css": "^1.1.0",
    "@eslint/json": "^1.2.0",
    "@eslint/markdown": "^8.0.1",
    "@limegrass/eslint-plugin-import-alias": "^1.6.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "8.x",
    "eslint-import-resolver-typescript": "4.x",
    "eslint-plugin-html": "^8.1.4",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-jsdoc": ">=62.8.1",
    "eslint-plugin-jsonc": "^3.1.2",
    "eslint-plugin-package-json": "^0.91.1",
    "eslint-plugin-regexp": "^3.1.0",
    "eslint-plugin-security": "^4.0.0",
    "eslint-plugin-sonarjs": "^4.0.2",
    "eslint-plugin-unicorn": "^64.0.0",
    "globals": "17.x",
    "semver": "7.x"
  },
  "devDependencies": {
    "@mephisto5558/better-types": "latest",
    "@types/eslint-plugin-security": "3.x",
    "@types/estree": "1.x",
    "@types/node": "20.x",
    "@types/semver": "7.x",
    "eslint": "^10.1.0",
    "eslint-plugin-eslint-plugin": "^7.3.2",
    "jiti": ">=2.2",
    "typescript": "^5.7.0 || ^6.0.0"
  },
  "peerDependencies": {
    "@mephisto5558/better-types": "latest",
    "eslint": "^10.1.0",
    "jiti": ">=2.2",
    "typescript": "^5.7.0 || ^6.0.0"
  },
  "engines": {
    "node": "^20.19.0 || ^22.13.0 || >=24"
  },
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": "^20.19.0 || ^22.13.0 || >=24",
      "onFail": "error"
    }
  }
}
